        </intent-filter>

        </activity> <activity
        android:name=".ChoixClasseActivity"
        android:screenOrientation="sensorLandscape"
        android:exported="false" />

        <activity
            android:name=".CustomActivity"
            android:screenOrientation="sensorLandscape"
            android:exported="false" />

        <activity

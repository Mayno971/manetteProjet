<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_manette"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1B26"
    android:keepScreenOn="true"
    tools:ignore="MissingDefaultResource">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_notification"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        android:translationZ="10dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:text="Alerte Système"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>


    <TextView
        android:id="@+id/text_player_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="PSEUDO - GUERRIER"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:id="@+id/health_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@+id/layout_top_buttons"
        app:layout_constraintStart_toEndOf="@+id/text_player_info"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="400dp">

        <ProgressBar
            android:id="@+id/health_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:max="100"
            android:progress="100"
            android:progressTint="#52B766" />

        <TextView
            android:id="@+id/text_health"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="100 / 100 PV"
            android:textColor="#81A1C1"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layout_top_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sos"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="12dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="SOS"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#F39C12"
            app:cornerRadius="25dp" />

        <ImageView
            android:id="@+id/btn_disconnect"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#E74C3C" />
    </LinearLayout>


    <com.example.applicationmobile.JoystickView
        android:id="@+id/joystick_left"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <Space
        android:id="@+id/center_buttons"
        android:layout_width="0dp"
        android:layout_height="5dp"
        android:layout_marginEnd="150dp"
        android:layout_marginBottom="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_y"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="40dp"
        android:text="Y"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#EBCB8B"
        app:cornerRadius="35dp"
        app:layout_constraintBottom_toTopOf="@+id/center_buttons"
        app:layout_constraintEnd_toEndOf="@+id/center_buttons"
        app:layout_constraintStart_toStartOf="@+id/center_buttons" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_a"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="40dp"
        android:text="A"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#A3BE8C"
        app:cornerRadius="45dp"
        app:layout_constraintEnd_toEndOf="@+id/center_buttons"
        app:layout_constraintStart_toStartOf="@+id/center_buttons"
        app:layout_constraintTop_toBottomOf="@+id/center_buttons" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_x"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="40dp"
        android:text="X"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#81A1C1"
        app:cornerRadius="35dp"
        app:layout_constraintBottom_toBottomOf="@+id/center_buttons"
        app:layout_constraintEnd_toStartOf="@+id/center_buttons"
        app:layout_constraintTop_toTopOf="@+id/center_buttons" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_b"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="40dp"
        android:text="B"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="#BF616A"
        app:cornerRadius="45dp"
        app:layout_constraintBottom_toBottomOf="@+id/center_buttons"
        app:layout_constraintStart_toEndOf="@+id/center_buttons"
        app:layout_constraintTop_toTopOf="@+id/center_buttons" />

</androidx.constraintlayout.widget.ConstraintLayout>